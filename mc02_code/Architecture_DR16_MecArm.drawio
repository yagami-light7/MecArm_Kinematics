        <mxCell id="n201" value="CallBack_USART.cpp&#xa;HAL_UARTEx_RxEventCallback()&#xa;UART5 -&gt; DR16_Module.DR16_Data_Processing()&#xa;UART7 -&gt; VT_Module.VT_Data_Processing()&#xa;USART10 -&gt; weak stub / 外部强定义覆盖" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" parent="1" vertex="1">
