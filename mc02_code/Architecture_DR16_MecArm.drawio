        <mxCell id="n502" value="STM32H723XG_FLASH.ld&#xa;新增 .RAM_D1 段&#xa;DR16 双DMA缓冲区放在 RAM_D1&#xa;避免落入默认 DTCM" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" parent="1" vertex="1">
          <mxGeometry x="1865" y="385" width="250" height="110" as="geometry" />
