        <mxCell id="n101" value="MX_FREERTOS_Init()&#xa;1. FDCAN_Filter_Init()&#xa;2. xTaskCreate(_Thread_MecArm_)&#xa;3. xTaskCreate(_Thread_RC_Hub_)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" parent="1" vertex="1">
