        <mxCell id="n501" value="Dev_Remote_Control.cpp&#xa;兼容层包装&#xa;保留旧接口名：&#xa;Remote_Control_Init()&#xa;Get_Remote_Control_Point()&#xa;UART5_ISR_Handler() / UART5_Error_Handler()" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" parent="1" vertex="1">
          <mxGeometry x="1865" y="170" width="250" height="150" as="geometry" />
